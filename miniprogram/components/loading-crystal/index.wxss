/* ============================================================
   Loading Crystal — 三阶段沉浸式等待
   ============================================================ */

.loading-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255, 248, 238, 0.97);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 0 40rpx;
}

/* ---- 阶段进度条 ---- */
.stage-bar {
  display: flex;
  align-items: center;
  margin-bottom: 60rpx;
  width: 100%;
  max-width: 560rpx;
}
.stage-node {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  opacity: 0.3;
  transition: opacity 0.5s;
}
.stage-node--active { opacity: 1; }
.stage-icon { font-size: 40rpx; }
.stage-label { font-size: 20rpx; color: #8B6F5E; }
.stage-line {
  flex: 1;
  height: 4rpx;
  background: #E8D8C0;
  margin: 0 8rpx;
  margin-bottom: 24rpx;
  border-radius: 2rpx;
  transition: background 0.5s;
}
.stage-line--active { background: var(--color-primary, #F5A623); }

/* ---- 主视觉区域 ---- */
.visual-wrap {
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

/* --- 阶段1：符咒 --- */
.talisman-wrapper {
  position: relative;
  width: 220rpx;
  height: 300rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: sway 3s ease-in-out infinite;
}
.talisman-paper {
  width: 140rpx;
  min-height: 280rpx;
  background: linear-gradient(180deg, #F2D060 0%, #E8C030 40%, #F0CA50 100%);
  border-radius: 8rpx 8rpx 12rpx 12rpx;
  border: 3rpx solid #A07820;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 14rpx 0;
  box-shadow: inset 0 0 20rpx rgba(160,120,32,.15), 0 8rpx 32rpx rgba(100,60,0,.25), 4rpx 4rpx 0 #C09020;
  position: relative;
  overflow: hidden;
}
.talisman-paper::before {
  content: '';
  position: absolute;
  top: 0; left: 10rpx; right: 10rpx; bottom: 0;
  background: repeating-linear-gradient(180deg, transparent, transparent 48rpx, rgba(160,120,32,.12) 48rpx, rgba(160,120,32,.12) 50rpx);
  pointer-events: none;
}
.talisman-paper::after {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 10rpx;
  background: #CC3300;
  border-radius: 8rpx 8rpx 0 0;
}
.talisman-seal { font-size: 28rpx; color: #CC3300; font-weight: bold; z-index: 1; }
.top-seal { margin-top: 18rpx; }
.bottom-seal { margin-bottom: 8rpx; font-size: 22rpx; }
.talisman-body { display: flex; flex-direction: column; align-items: center; gap: 2rpx; z-index: 1; }
.talisman-char {
  font-size: 34rpx;
  font-weight: bold;
  color: #5C0000;
  font-family: "华文行楷", "STKaiti", cursive;
  line-height: 1.3;
  opacity: 0;
  animation: inkDrop 0.4s ease forwards;
}
.char-1 { animation-delay: 0.1s; }
.char-2 { animation-delay: 0.35s; }
.char-3 { animation-delay: 0.6s; }
.char-4 { animation-delay: 0.85s; }
.char-5 { animation-delay: 1.1s; }
.float-deco {
  position: absolute;
  font-size: 28rpx;
  animation: floatAround 4s ease-in-out infinite;
}
.deco-1 { top: 0; left: 10rpx; animation-delay: 0s; }
.deco-2 { bottom: 20rpx; right: 10rpx; animation-delay: -1.3s; }
.deco-3 { top: 40rpx; right: 0; animation-delay: -2.6s; }

/* --- 阶段2：水晶球 --- */
.crystal-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}
.crystal-glow {
  position: absolute;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(184,158,212,.45) 0%, transparent 70%);
  animation: glowPulse 2s ease-in-out infinite;
}
.crystal-ball {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #EEE0FF, #C8AAED 50%, #9B72D4);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(155,114,212,.45), inset 0 -8rpx 20rpx rgba(255,255,255,.25);
  animation: crystalFloat 3s ease-in-out infinite;
  position: relative;
}
.crystal-inner { font-size: 72rpx; }
.crystal-star {
  position: absolute;
  font-size: 18rpx;
  color: #FFD060;
  animation: starSpin 4s linear infinite;
}
.s1 { top: 10rpx; left: 20rpx; animation-delay: 0s; }
.s2 { top: 20rpx; right: 10rpx; animation-delay: -1s; }
.s3 { bottom: 10rpx; left: 30rpx; animation-delay: -2s; }
.s4 { bottom: 20rpx; right: 20rpx; animation-delay: -3s; }
.fortune-revealed {
  background: linear-gradient(135deg, #FFD060, #F5A623);
  padding: 10rpx 36rpx;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(245,166,35,.35);
}
.revealed-text {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

/* --- 阶段3：画布绘制 --- */
.canvas-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  position: relative;
}
.paint-frame {
  width: 260rpx;
  height: 220rpx;
  border: 4rpx solid #D4B896;
  border-radius: 16rpx;
  background: #FFFBF5;
  overflow: hidden;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(180,120,60,.15);
}
.paint-progress {
  position: absolute;
  top: 0; left: 0; bottom: 0;
  background: linear-gradient(90deg, rgba(200,170,237,.25), rgba(245,166,35,.15));
  transition: width 3s ease;
}
.paint-emoji {
  font-size: 80rpx;
  z-index: 1;
  animation: paintBounce 1.5s ease-in-out infinite;
}
.brush-wrap {
  position: absolute;
  top: 16rpx;
  right: -10rpx;
  animation: brushMove 2s ease-in-out infinite;
}
.brush-icon { font-size: 48rpx; transform: rotate(-30deg); display: block; }
.paint-sparks {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
}
.spark {
  position: absolute;
  font-size: 20rpx;
  animation: sparkFly 2s ease-in-out infinite;
}
.sk1 { top: 20rpx; right: 20rpx; animation-delay: 0s; color: #F5A623; }
.sk2 { bottom: 30rpx; right: 40rpx; animation-delay: -0.7s; color: #B89ED4; }
.sk3 { top: 40rpx; left: 20rpx; animation-delay: -1.4s; color: #F5A623; }

/* ---- 文字区域 ---- */
.text-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  width: 100%;
}
.stage-title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text, #3A2A1A);
  letter-spacing: 3rpx;
}
.loading-main-text {
  font-size: 28rpx;
  color: #8B6F5E;
  text-align: center;
  line-height: 1.7;
  padding: 0 20rpx;
  min-height: 80rpx;
  animation: textFade 0.4s ease;
}
.loading-wait-hint {
  font-size: 24rpx;
  color: #B89ED4;
  text-align: center;
}
.loading-timer {
  font-size: 22rpx;
  color: #C8C8C8;
}

/* ---- 动画 ---- */
@keyframes sway {
  0%, 100% { transform: rotate(-2deg); }
  50% { transform: rotate(2deg); }
}
@keyframes inkDrop {
  from { opacity: 0; transform: translateY(-8rpx); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes floatAround {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.7; }
  50% { transform: translateY(-20rpx) scale(1.1); opacity: 1; }
}
@keyframes glowPulse {
  0%, 100% { transform: scale(1); opacity: 0.6; }
  50% { transform: scale(1.2); opacity: 1; }
}
@keyframes crystalFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}
@keyframes starSpin {
  0% { transform: rotate(0deg) translateX(70rpx) rotate(0deg); opacity: 0.8; }
  100% { transform: rotate(360deg) translateX(70rpx) rotate(-360deg); opacity: 0.8; }
}
@keyframes paintBounce {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}
@keyframes brushMove {
  0%, 100% { transform: translate(0, 0) rotate(-30deg); }
  25% { transform: translate(-40rpx, 20rpx) rotate(-20deg); }
  50% { transform: translate(-80rpx, 40rpx) rotate(-35deg); }
  75% { transform: translate(-40rpx, 60rpx) rotate(-25deg); }
}
@keyframes sparkFly {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0; }
  50% { transform: translateY(-20rpx) scale(1.3); opacity: 1; }
}
@keyframes textFade {
  from { opacity: 0; transform: translateY(6rpx); }
  to { opacity: 1; transform: translateY(0); }
}
