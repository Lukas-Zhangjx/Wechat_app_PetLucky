<scroll-view class="page-container" scroll-y>
  <view class="sign-page">

    <!-- 顶部标题区 -->
    <view class="sign-header">
      <text class="header-deco">🌙 ✨ 🌙</text>
      <text class="header-title">今日灵签</text>
      <text class="header-sub">每日一签 · 诚心则灵</text>
    </view>

    <!-- ===== 未求签状态 ===== -->
    <view class="sign-main-card sign-main-card--unseen" wx:if="{{!hasDrawn}}">

      <!-- 签筒 -->
      <view class="stick-scene {{isDrawing ? 'stick-scene--shaking' : ''}}">
        <view class="jar-glow"></view>
        <view class="sticks-layer">
          <view class="stick stk-1"></view>
          <view class="stick stk-2"></view>
          <view class="stick stk-3"></view>
          <view class="stick stk-4"></view>
          <view class="stick stk-5"></view>
          <view class="stick stk-6"></view>
          <view class="stick stk-7"></view>
        </view>
        <view class="stick-jar">
          <view class="jar-top-rim"></view>
        </view>
      </view>

      <text class="unseen-title">今日还未求签</text>
      <text class="unseen-hint">静心诚意，点击下方求签</text>

      <view
        class="draw-btn {{isDrawing ? 'draw-btn--loading' : ''}}"
        bindtap="onDrawSign"
      >
        <text class="draw-btn-icon">{{isDrawing ? '✨' : '🪄'}}</text>
        <text class="draw-btn-text">{{isDrawing ? '天机流转中…' : '求  签'}}</text>
      </view>

    </view>

    <!-- ===== 已求签状态 ===== -->
    <view class="sign-main-card {{cardClass}}" wx:else>

      <!-- 等级 badge -->
      <view class="grade-badge-wrap">
        <view class="grade-badge {{gradeClass}}">
          <text class="grade-text">{{signGrade}}</text>
        </view>
        <text class="grade-hint">
          {{signGrade === '大吉' ? '🎉 今日大运！' : signGrade === '吉' ? '✨ 今日顺遂' : '🍀 平安无事'}}
        </text>
      </view>

      <!-- 签文内容 -->
      <view
        class="sign-inner {{shakeAnim ? 'sign-inner--shake' : ''}}"
        bindtap="onShake"
      >
        <text class="revealed-scroll">📜</text>
        <text class="revealed-text">{{todaySign}}</text>
        <text class="revealed-hint">轻触感受能量 · 明日更新</text>
      </view>

    </view>

    <!-- 底部说明 -->
    <view class="sign-footer">
      <text class="footer-text">✦ 每日一签，旨在娱乐，请勿过度解读 ✦</text>
    </view>

  </view>
</scroll-view>
