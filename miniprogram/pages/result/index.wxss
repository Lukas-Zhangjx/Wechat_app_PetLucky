/* ============================================
   算命结果页样式 — 对齐概念图"星月守护型"卡片风格
   ============================================ */

.result-wrap {
  padding: 32rpx 32rpx 40rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ---- 命格主卡（最重要的视觉元素） ---- */
.fortune-hero {
  text-align: center;
  padding: 56rpx 36rpx 48rpx;
  border-radius: 36rpx;
  position: relative;
  overflow: hidden;
}

/* SSR 金色渐变 */
.fortune-hero--ssr {
  background: linear-gradient(160deg, #FFF9E6 0%, #FFF0C0 50%, #FFE090 100%);
  border: 2rpx solid #F5C842;
  box-shadow: 0 10rpx 36rpx rgba(245, 166, 35, 0.22);
}
/* SR 薰衣草渐变 */
.fortune-hero--sr {
  background: linear-gradient(160deg, #FBF5FF 0%, #EEE0FF 50%, #E0CCFF 100%);
  border: 2rpx solid var(--color-secondary);
  box-shadow: 0 10rpx 36rpx rgba(184, 158, 212, 0.22);
}
/* R 暖奶油 */
.fortune-hero--r {
  background: linear-gradient(160deg, #FFF9F0 0%, #FFF0DC 100%);
  border: 2rpx solid var(--color-border);
  box-shadow: 0 6rpx 20rpx rgba(180, 120, 60, 0.10);
}

/* 右上角散落星星装饰 */
.fortune-hero::before {
  content: "✦  ✦";
  position: absolute;
  top: 24rpx; right: 32rpx;
  font-size: 24rpx;
  color: var(--color-primary);
  opacity: 0.45;
  letter-spacing: 16rpx;
}
.fortune-hero::after {
  content: "✦";
  position: absolute;
  bottom: 28rpx; left: 32rpx;
  font-size: 20rpx;
  color: var(--color-secondary);
  opacity: 0.45;
}

/* 星星装饰行 */
.hero-deco {
  font-size: 24rpx;
  letter-spacing: 14rpx;
  opacity: 0.55;
  margin-bottom: 24rpx;
  display: block;
}

/* 稀有度标签行 */
.rarity-row { margin-bottom: 20rpx; }

/* 本页自用 rarity-badge（覆盖 app.wxss） */
.rarity-badge {
  display: inline-block;
  padding: 8rpx 32rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: bold;
  letter-spacing: 3rpx;
}
.badge--ssr {
  background: linear-gradient(135deg, #FFD060, #F5A623, #FF8C69);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(245, 166, 35, 0.50);
}
.badge--sr {
  background: linear-gradient(135deg, #C8AAED, #B89ED4);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(184, 158, 212, 0.50);
}
.badge--r {
  background: var(--color-border);
  color: var(--color-text-sub);
}

/* 宠物头像容器 */
.pet-avatar-wrap {
  position: relative;
  width: 260rpx;
  height: 260rpx;
  margin: 12rpx auto 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 光晕底层 */
.pet-avatar-glow {
  position: absolute;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  opacity: 0.35;
  filter: blur(20rpx);
}
.badge--ssr--glow { background: radial-gradient(circle, #FFD060, #F5A623); }
.badge--sr--glow  { background: radial-gradient(circle, #C8AAED, #B89ED4); }
.badge--r--glow   { background: radial-gradient(circle, #FFD8A0, #FFBE45); }

/* 宠物插画 */
.pet-avatar-img {
  width: 240rpx;
  height: 240rpx;
  display: block;
  position: relative;
  z-index: 1;
  animation: heroBounce 3s ease-in-out infinite;
}

/* 浮动小星星 */
.pet-avatar-stars {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  pointer-events: none;
  z-index: 2;
}
.avatar-star {
  position: absolute;
  font-size: 22rpx;
  color: var(--color-primary);
  animation: starFloat 2.5s ease-in-out infinite;
}
.s1 { top: 10rpx; left: 20rpx; animation-delay: 0s; }
.s2 { top: 20rpx; right: 10rpx; animation-delay: 0.8s; color: var(--color-secondary); }
.s3 { bottom: 10rpx; left: 50%; animation-delay: 1.6s; }

@keyframes starFloat {
  0%, 100% { transform: translateY(0) scale(1); opacity: 0.7; }
  50% { transform: translateY(-10rpx) scale(1.2); opacity: 1; }
}

/* 命格名称（最大最醒目） */
.fortune-type {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: var(--color-text);
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

/* 命格描述 */
.fortune-desc {
  display: block;
  font-size: 28rpx;
  color: var(--color-text-sub);
  line-height: 1.9;
  margin-bottom: 20rpx;
}

/* 宠物名 */
.pet-name-label {
  font-size: 30rpx;
  color: var(--color-primary);
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* ---- 通用卡片标题 ---- */
.card-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 24rpx;
  font-family: var(--font-title);
}

/* ---- 今日运势信息卡 ---- */
.info-card { display: flex; flex-direction: column; }
.fortune-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--color-border-light);
}
.fortune-row:last-child { border-bottom: none; }
.row-label { font-size: 28rpx; color: var(--color-text-sub); }
.row-value { font-size: 28rpx; color: var(--color-text); font-weight: 500; }
.color-row { display: flex; align-items: center; gap: 12rpx; }
.color-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 3rpx solid var(--color-border);
}

/* ---- 今日宜忌卡 ---- */
.do-dont-card {
  display: flex;
  gap: 0;
  padding: 32rpx;
}
.do-col, .dont-col { flex: 1; }
.divider-v {
  width: 2rpx;
  background: var(--color-border-light);
  margin: 0 24rpx;
}
.do-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-success);
  margin-bottom: 20rpx;
}
.dont-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-error);
  margin-bottom: 20rpx;
}
.do-item, .dont-item {
  display: flex;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 14rpx;
}
.do-check  { color: var(--color-success); font-weight: bold; flex-shrink: 0; }
.dont-cross { color: var(--color-error);   font-weight: bold; flex-shrink: 0; }
.do-text, .dont-text {
  font-size: 26rpx;
  color: var(--color-text-sub);
  line-height: 1.5;
}

/* ---- 今日灵签卡 ---- */
.sign-result-card {
  background: linear-gradient(160deg, #FFF9F0, #FFE9C0);
  text-align: center;
}
.sign-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 20rpx;
}
.sign-content {
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 2.0;
  font-style: italic;
}

/* ---- 底部操作按钮 ---- */
.action-btns {
  display: flex;
  gap: 20rpx;
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}
.retry-btn, .share-btn { flex: 1; font-size: 30rpx; }

.action-btns-row2 {
  padding-bottom: 40rpx;
}
.btn-save-img {
  width: 100%;
  background: linear-gradient(135deg, #B89ED4, #9B72D4);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 56rpx;
  padding: 28rpx 0;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(155,114,212,0.35);
}
.btn-save-img::after { border: none; }

/* ---- 用户真实照片专属样式 ---- */
.pet-avatar-img--generated {
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
}
.generated-badge {
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, #C8AAED, #B89ED4);
  color: #fff;
  font-size: 20rpx;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(184,158,212,0.45);
}

/* ---- 早中晚时辰卡 ---- */
.timeline-card { padding: 32rpx 36rpx; }
.timeline-item {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
  align-items: flex-start;
}
.timeline-item:last-child { margin-bottom: 0; }
.timeline-dot {
  width: 56rpx; height: 56rpx;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 24rpx; font-weight: bold; color: #fff;
  flex-shrink: 0;
  margin-top: 4rpx;
}
.dot--morning  { background: linear-gradient(135deg, #FFD060, #F5A623); }
.dot--afternoon{ background: linear-gradient(135deg, #FF9A60, #E8792A); }
.dot--evening  { background: linear-gradient(135deg, #C8AAED, #9B72D4); }
.timeline-content { flex: 1; }
.timeline-label {
  display: block;
  font-size: 24rpx; font-weight: bold;
  color: var(--color-text-sub);
  margin-bottom: 8rpx;
}
.timeline-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
}
.timing-val { color: var(--color-primary); font-size: 26rpx; }

/* ---- 影视彩蛋卡 ---- */
.pop-card {
  background: linear-gradient(135deg, #F0F8FF, #E8F4FF);
  border: 2rpx solid #B0D4F0;
  padding: 32rpx 36rpx;
}
.pop-text {
  display: block;
  font-size: 28rpx;
  color: #3A6EA8;
  line-height: 1.8;
}

/* ---- 人生阶段卡 ---- */
.stages-card { padding: 32rpx 36rpx; }
.stage-item {
  margin-bottom: 36rpx;
  padding-bottom: 36rpx;
  border-bottom: 2rpx dashed var(--color-border-light);
}
.stage-item:last-child { margin-bottom: 0; padding-bottom: 0; border-bottom: none; }
.stage-header { margin-bottom: 12rpx; }
.stage-period {
  display: inline-block;
  font-size: 22rpx;
  background: var(--color-primary);
  color: #fff;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-right: 12rpx;
}
.stage-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
  font-family: 'KuaiLe', sans-serif;
}
.stage-reading {
  display: block;
  font-size: 27rpx;
  color: var(--color-text);
  line-height: 1.85;
}

/* ---- 命格解读专属样式 ---- */
.destiny-card { padding: 32rpx 36rpx; }
.destiny-text {
  display: block;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.8;
}
.obstacles-card { background: linear-gradient(135deg, #FFF9F0, #FFF0DC); }
.obstacle-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 20rpx;
}
.obstacle-dot {
  color: #E8792A;
  font-size: 28rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}
.obstacle-text {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.7;
  flex: 1;
}
.bond-card { background: linear-gradient(135deg, #FFF5F8, #FFE8EF); }
.bond-text { color: #C05080; }

/* ---- 算命模式选择按钮 ---- */
.mode-btns {
  display: flex;
  gap: 20rpx;
}
.mode-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 16rpx;
  background: #fff;
  border: 3rpx solid var(--color-border-light);
  border-radius: 24rpx;
  gap: 8rpx;
}
.mode-btn--active {
  border-color: var(--color-primary);
  background: linear-gradient(135deg, #FFF9F0, #FFF3DC);
  box-shadow: 0 4rpx 16rpx rgba(245, 166, 35, 0.20);
}
.mode-icon { font-size: 48rpx; }
.mode-name {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}
.mode-desc {
  font-size: 22rpx;
  color: var(--color-text-sub);
}

/* ---- 动画 ---- */
@keyframes heroBounce {
  0%, 100% { transform: translateY(0) scale(1); }
  50%       { transform: translateY(-12rpx) scale(1.04); }
}
