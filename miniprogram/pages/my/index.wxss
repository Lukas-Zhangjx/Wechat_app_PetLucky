.page-container {
  min-height: 100vh;
  background: var(--color-bg);
}

/* ──────── 顶部栏 ──────── */
.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 40rpx 28rpx;
  background: linear-gradient(160deg, #FFF8EE 0%, #FFECD6 100%);
}
.top-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text);
  font-family: var(--font-title, sans-serif);
}
.top-sub {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-top: 4rpx;
}

.usage-badge {
  background: var(--color-primary);
  border-radius: 20rpx;
  padding: 14rpx 22rpx;
  text-align: center;
}
.usage-label { display: block; font-size: 18rpx; color: rgba(255,255,255,0.85); }
.usage-num   { display: block; font-size: 44rpx; font-weight: bold; color: #fff; line-height: 1.1; }
.usage-unit  { display: block; font-size: 18rpx; color: rgba(255,255,255,0.85); }

/* ──────── section 通用 ──────── */
.section { padding: 28rpx 40rpx 20rpx; }

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}
.section-header--records {
  padding: 24rpx 40rpx 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}
.add-btn {
  font-size: 24rpx;
  color: var(--color-primary);
  background: rgba(245,166,35,0.12);
  padding: 8rpx 24rpx;
  border-radius: 20rpx;
  font-weight: 600;
}
.section-divider {
  height: 16rpx;
  background: var(--color-bg);
}

/* ──────── 宠物卡片 ──────── */
.pets-scroll {
  width: 100%;
}
.pets-row {
  display: inline-flex;
  gap: 20rpx;
  padding-bottom: 8rpx;
}
.pet-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  background: #fff;
  border: 2rpx solid #F0E0C8;
  border-radius: 28rpx;
  padding: 28rpx 28rpx 20rpx;
  width: 208rpx;
  box-shadow: 0 4rpx 18rpx rgba(180,120,60,.08);
  flex-shrink: 0;
}
.pet-card:active { transform: scale(0.97); }

.pet-card-emoji {
  font-size: 60rpx;
  margin-bottom: 8rpx;
}
.pet-card-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 4rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.pet-card-meta {
  font-size: 20rpx;
  color: var(--color-text-sub);
  margin-bottom: 18rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}
.pet-fortune-btn {
  background: linear-gradient(135deg, #FFD060, #F5A623);
  color: #fff;
  font-size: 22rpx;
  font-weight: bold;
  text-align: center;
  padding: 12rpx 0;
  border-radius: 20rpx;
  width: 100%;
}
.pet-card-tools {
  display: flex;
  gap: 16rpx;
  margin-top: 14rpx;
}
.pet-tool-btn {
  font-size: 26rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  background: #F8F4EE;
}
.pet-tool-btn--del {
  background: #FFF0F0;
}

/* ──────── 空状态（无宠物） ──────── */
.pets-empty {
  background: #fff;
  border: 2rpx dashed #F0E0C8;
  border-radius: 24rpx;
  padding: 44rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}
.pets-empty:active { background: #FFF8EE; }
.pets-empty-icon {
  font-size: 64rpx;
  color: var(--color-primary);
  opacity: 0.5;
  line-height: 1;
  font-weight: 300;
}
.pets-empty-text {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text-sub);
}
.pets-empty-sub {
  font-size: 22rpx;
  color: #C8B8A0;
  text-align: center;
}

/* ──────── 算命记录 ──────── */
.records-scroll { height: 56vh; }
.records-list { padding: 0 40rpx; display: flex; flex-direction: column; gap: 16rpx; }

.record-item { padding: 24rpx; }
.record-row { display: flex; align-items: center; gap: 16rpx; }
.record-emoji { font-size: 56rpx; flex-shrink: 0; }
.record-info { flex: 1; }
.record-name { display: block; font-size: 30rpx; font-weight: bold; color: var(--color-text); }
.record-meta-row { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx; }
.record-fortune-type { font-size: 26rpx; color: var(--color-text-sub); }

.record-right { text-align: right; flex-shrink: 0; }
.record-date  { display: block; font-size: 22rpx; color: var(--color-text-sub); }
.expand-arrow { display: block; font-size: 22rpx; color: var(--color-text-sub); margin-top: 8rpx; }

.record-detail { padding-top: 16rpx; }
.detail-desc { display: block; font-size: 26rpx; color: var(--color-text-sub); line-height: 1.7; margin-bottom: 16rpx; }
.detail-fortune-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.detail-label { font-size: 26rpx; color: var(--color-text-sub); }
.color-row { display: flex; align-items: center; gap: 10rpx; }
.color-dot { width: 28rpx; height: 28rpx; border-radius: 50%; border: 2rpx solid var(--color-border); }
.detail-sign {
  display: block;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
  font-style: italic;
  margin-top: 8rpx;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
}

/* ──────── 无记录空状态 ──────── */
.records-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 80rpx 40rpx;
}
.empty-emoji  { font-size: 96rpx; margin-bottom: 20rpx; opacity: 0.5; display: block; }
.empty-title  { font-size: 32rpx; font-weight: bold; color: var(--color-text-sub); margin-bottom: 10rpx; }
.empty-sub    { font-size: 26rpx; color: var(--color-text-sub); margin-bottom: 40rpx; }
.go-btn { font-size: 30rpx; padding: 24rpx 64rpx; }

/* ──────── 宠物照片选择器 ──────── */
.photo-picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 0 20rpx;
  flex-direction: column;
  gap: 12rpx;
}
.photo-preview {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid #F0E0C8;
  box-shadow: 0 4rpx 16rpx rgba(180,120,60,.12);
  display: block;
}
.photo-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 3rpx dashed #D0C0B0;
  background: #FFF8F0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}
.photo-placeholder-icon { font-size: 44rpx; }
.photo-placeholder-text { font-size: 20rpx; color: #C8B8A0; }
.photo-change-hint { font-size: 22rpx; color: var(--color-primary); }

/* 宠物卡片照片头像 */
.pet-card-photo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  border: 3rpx solid #F0E0C8;
  margin-bottom: 8rpx;
  display: block;
}

/* ──────── 意见反馈 ──────── */
.feedback-section {
  padding: 24rpx 40rpx 40rpx;
}
.feedback-btn {
  display: flex;
  align-items: center;
  gap: 20rpx;
  width: 100%;
  background: #fff;
  border: 2rpx solid #F0E0C8;
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(180,120,60,.06);
  /* 重置微信 button 默认样式 */
  line-height: normal;
  font-size: inherit;
  color: inherit;
}
.feedback-btn::after { border: none; }
.feedback-btn:active { background: #FFF8EE; }

.feedback-icon {
  font-size: 48rpx;
  flex-shrink: 0;
}
.feedback-text-wrap {
  flex: 1;
  text-align: left;
}
.feedback-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
}
.feedback-sub {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-sub);
  margin-top: 4rpx;
}
.feedback-arrow {
  font-size: 40rpx;
  color: #C8B8A0;
  flex-shrink: 0;
}

/* ──────── Modal 底部弹窗 ──────── */
.modal-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.48);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.modal-sheet {
  background: #fff;
  border-radius: 40rpx 40rpx 0 0;
  width: 100%;
  padding: 20rpx 40rpx 60rpx;
  max-height: 88vh;
  overflow-y: auto;
}
.modal-handle {
  width: 72rpx;
  height: 8rpx;
  background: #E0D0C0;
  border-radius: 8rpx;
  margin: 0 auto 32rpx;
}
.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}
.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text);
}
.modal-close {
  font-size: 28rpx;
  color: var(--color-text-sub);
  padding: 8rpx 16rpx;
}
.modal-form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 26rpx 0;
  min-height: 88rpx;
}
.modal-save-btn {
  margin-top: 36rpx;
  width: 100%;
}

/* 表单组件（复用 quiz 里的样式） */
.form-label {
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  flex-shrink: 0;
  margin-right: 20rpx;
}
.required  { color: var(--color-error, #E05050); font-size: 24rpx; }
.form-input {
  flex: 1;
  font-size: 26rpx;
  color: var(--color-text);
  text-align: right;
}
.input-ph { font-size: 24rpx; color: #C8B8AA; }
.gender-btns { display: flex; gap: 16rpx; }
.gender-btn {
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-sub);
  border: 2rpx solid var(--color-border);
  background: var(--color-bg);
}
.gender-btn--active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}
.picker-val {
  font-size: 26rpx;
  color: var(--color-text);
  display: flex;
  align-items: center;
  gap: 8rpx;
}
.picker-arrow { color: var(--color-text-sub); font-size: 32rpx; }
