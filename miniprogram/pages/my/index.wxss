.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 48rpx 40rpx 24rpx;
  background: linear-gradient(160deg, #FFF8EE 0%, #FFECD6 100%);
}
.user-section { display: flex; align-items: center; gap: 20rpx; }
.user-avatar { font-size: 72rpx; }
.user-label { display: block; font-size: 32rpx; font-weight: bold; color: var(--color-text); }
.user-sub { display: block; font-size: 24rpx; color: var(--color-text-sub); margin-top: 4rpx; }

.usage-badge {
  background: var(--color-primary);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}
.usage-label { display: block; font-size: 20rpx; color: rgba(255,255,255,0.8); }
.usage-num { display: block; font-size: 48rpx; font-weight: bold; color: #fff; line-height: 1; }
.usage-unit { display: block; font-size: 20rpx; color: rgba(255,255,255,0.8); }

.records-list { padding: 24rpx 40rpx 0; display: flex; flex-direction: column; gap: 16rpx; }

.record-item { padding: 24rpx; }
.record-row { display: flex; align-items: center; gap: 16rpx; }
.record-emoji { font-size: 60rpx; flex-shrink: 0; }
.record-info { flex: 1; }
.record-name { display: block; font-size: 30rpx; font-weight: bold; color: var(--color-text); }
.record-meta-row { display: flex; align-items: center; gap: 12rpx; margin-top: 8rpx; }
.record-fortune-type { font-size: 26rpx; color: var(--color-text-sub); }

.record-right { text-align: right; flex-shrink: 0; }
.record-date { display: block; font-size: 22rpx; color: var(--color-text-sub); }
.expand-arrow { display: block; font-size: 22rpx; color: var(--color-text-sub); margin-top: 8rpx; }

.record-detail { padding-top: 16rpx; }
.detail-desc { display: block; font-size: 26rpx; color: var(--color-text-sub); line-height: 1.7; margin-bottom: 16rpx; }
.detail-fortune-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.detail-label { font-size: 26rpx; color: var(--color-text-sub); }
.color-row { display: flex; align-items: center; gap: 10rpx; }
.color-dot { width: 28rpx; height: 28rpx; border-radius: 50%; border: 2rpx solid var(--color-border); }
.detail-sign {
  display: block;
  font-size: 26rpx;
  color: var(--color-text);
  line-height: 1.7;
  font-style: italic;
  margin-top: 8rpx;
  padding: 16rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 80rpx;
}
.empty-emoji { font-size: 120rpx; margin-bottom: 24rpx; opacity: 0.6; }
.empty-title { font-size: 36rpx; font-weight: bold; color: var(--color-text-sub); margin-bottom: 12rpx; }
.empty-sub { font-size: 28rpx; color: var(--color-text-sub); margin-bottom: 48rpx; }
.go-btn { font-size: 32rpx; padding: 28rpx 80rpx; }
