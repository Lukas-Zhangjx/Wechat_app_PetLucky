/* ============================================
   首页样式
   ============================================ */

/* ---- 欢迎遮罩 ---- */
.welcome-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: var(--color-bg);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 100;
  transition: opacity 0.6s ease;
}
.welcome-overlay--hidden { opacity: 0; pointer-events: none; }

/* ---- 爪印背景 ---- */
.paw {
  position: absolute;
  pointer-events: none;
  user-select: none;
  line-height: 1;
}
.pw-1  { font-size: 52rpx; top: 6%;   left: 4%;   opacity: 0.10; transform: rotate(-25deg); }
.pw-2  { font-size: 36rpx; top: 12%;  right: 8%;  opacity: 0.13; transform: rotate(20deg);  }
.pw-3  { font-size: 44rpx; top: 22%;  left: 14%;  opacity: 0.08; transform: rotate(40deg);  }
.pw-4  { font-size: 30rpx; top: 18%;  right: 3%;  opacity: 0.12; transform: rotate(-10deg); }
.pw-5  { font-size: 48rpx; top: 38%;  left: 2%;   opacity: 0.09; transform: rotate(15deg);  }
.pw-6  { font-size: 32rpx; top: 42%;  right: 6%;  opacity: 0.11; transform: rotate(-30deg); }
.pw-7  { font-size: 56rpx; top: 60%;  left: 8%;   opacity: 0.08; transform: rotate(35deg);  }
.pw-8  { font-size: 38rpx; top: 55%;  right: 5%;  opacity: 0.13; transform: rotate(-20deg); }
.pw-9  { font-size: 42rpx; top: 74%;  left: 3%;   opacity: 0.10; transform: rotate(10deg);  }
.pw-10 { font-size: 34rpx; top: 78%;  right: 10%; opacity: 0.09; transform: rotate(-40deg); }
.pw-11 { font-size: 28rpx; top: 88%;  left: 18%;  opacity: 0.12; transform: rotate(25deg);  }
.pw-12 { font-size: 46rpx; top: 85%;  right: 2%;  opacity: 0.08; transform: rotate(-15deg); }

/* ---- 手绘签 ---- */
.slip-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: slipSway 2.4s ease-in-out infinite alternate;
  transform-origin: top center;
  margin-bottom: 8rpx;
}
/* 签上方的细绳 */
.slip-string {
  width: 4rpx;
  height: 48rpx;
  background: linear-gradient(to bottom, transparent, #C4A882);
  border-radius: 2rpx;
}
/* 签本体 */
.fortune-slip {
  width: 120rpx;
  background: linear-gradient(170deg, #FFFBF0 0%, #FFF3CC 60%, #FFEAA0 100%);
  border: 3rpx solid #E8B84B;
  border-radius: 60rpx 60rpx 16rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx 22rpx;
  box-shadow:
    0 8rpx 28rpx rgba(200, 140, 30, 0.30),
    inset 0 2rpx 6rpx rgba(255, 255, 255, 0.8);
  position: relative;
}
/* 顶部红色印章圆点 */
.slip-seal {
  width: 32rpx;
  height: 32rpx;
  background: radial-gradient(circle at 40% 35%, #FF6B6B, #D43030);
  border-radius: 50%;
  margin-bottom: 10rpx;
  box-shadow: 0 2rpx 6rpx rgba(212, 48, 48, 0.4);
}
/* "大" "吉" 两个竖排大字 */
.slip-top {
  font-size: 30rpx;
  font-weight: bold;
  color: #C47A1E;
  line-height: 1.3;
  font-family: var(--font-title);
  letter-spacing: 0;
}
/* 分割线 */
.slip-divider {
  width: 64rpx;
  height: 1rpx;
  background: rgba(200, 140, 30, 0.35);
  margin: 8rpx 0;
}
/* 中央大"签"字 */
.slip-main-char {
  font-size: 56rpx;
  font-weight: bold;
  color: #B5640A;
  line-height: 1.1;
  font-family: var(--font-title);
  text-shadow: 1rpx 2rpx 4rpx rgba(180, 100, 10, 0.25);
}
/* 底部品牌小字 */
.slip-brand {
  font-size: 18rpx;
  color: #C4A882;
  letter-spacing: 3rpx;
  font-family: var(--font-title);
}

/* ---- 欢迎标题 ---- */
.welcome-title {
  font-size: 68rpx;
  font-weight: bold;
  color: var(--color-primary);
  margin-top: 24rpx;
  letter-spacing: 8rpx;
  font-family: var(--font-title);
}
.welcome-sub { font-size: 28rpx; color: var(--color-text-sub); margin-top: 12rpx; }

/* ---- 背景星星月亮装饰层 ---- */
.bg-deco {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 900rpx;   /* 覆盖 banner + 按钮区域 */
  pointer-events: none;
  z-index: 0;
  overflow: hidden;
}
/* 通用样式 */
.bd {
  position: absolute;
  pointer-events: none;
  user-select: none;
}
.bd-star {
  color: var(--color-primary);
  opacity: 0.35;
  font-size: 22rpx;
}
.bd-moon {
  opacity: 0.22;
  font-size: 28rpx;
}
/* 各自位置 + 轻微浮动动画 */
.bd-1  { top: 60rpx;  left: 30rpx;  animation: bdFloat 4.2s ease-in-out infinite alternate; }
.bd-2  { top: 40rpx;  right: 50rpx; animation: bdFloat 3.8s ease-in-out infinite alternate-reverse; }
.bd-3  { top: 130rpx; right: 28rpx; animation: bdFloat 5.1s ease-in-out infinite alternate; }
.bd-4  { top: 200rpx; left: 18rpx;  animation: bdFloat 3.5s ease-in-out infinite alternate-reverse; font-size: 16rpx; }
.bd-5  { top: 300rpx; left: 44rpx;  animation: bdFloat 4.7s ease-in-out infinite alternate; }
.bd-6  { top: 260rpx; right: 20rpx; animation: bdFloat 5.3s ease-in-out infinite alternate-reverse; font-size: 16rpx; }
.bd-7  { top: 480rpx; right: 36rpx; animation: bdFloat 4.0s ease-in-out infinite alternate; }
.bd-8  { top: 560rpx; left: 26rpx;  animation: bdFloat 3.6s ease-in-out infinite alternate-reverse; }
.bd-9  { top: 620rpx; right: 54rpx; animation: bdFloat 5.5s ease-in-out infinite alternate; font-size: 16rpx; }
.bd-10 { top: 700rpx; left: 50rpx;  animation: bdFloat 4.4s ease-in-out infinite alternate-reverse; font-size: 16rpx; }

/* ---- Banner ---- */
.banner {
  position: relative;
  background: linear-gradient(180deg, #FFF5E4 0%, #FFE9C0 100%);
  z-index: 1;
}
/* 文字标题叠在图片上方 */
.banner-header {
  padding: 36rpx 40rpx 12rpx;
  text-align: center;
}
.banner-app-name {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: var(--color-text);
  letter-spacing: 4rpx;
  font-family: var(--font-title);
}
.banner-tagline {
  display: block;
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-top: 6rpx;
  font-family: var(--font-title);
}
/* 四周渐隐：用椭圆渐变遮罩，边缘自然融入背景 */
.banner-img {
  width: 100%;
  height: 360rpx;
  display: block;
  mask-image: radial-gradient(ellipse 88% 90% at 50% 42%, black 35%, transparent 80%);
  -webkit-mask-image: radial-gradient(ellipse 88% 90% at 50% 42%, black 35%, transparent 80%);
}

/* ---- CTA 按钮 ---- */
.cta-wrap {
  padding: 28rpx 40rpx 0;
  position: relative;
  z-index: 1;
}
.cta-btn {
  width: 100%;
  font-size: 30rpx;
  letter-spacing: 2rpx;
  white-space: nowrap;
}

/* ---- 宠物快捷入口：横排 4 列 ---- */
.shortcut-section {
  padding: 24rpx 24rpx 0;
  position: relative;
  z-index: 1;
}
.shortcut-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 14rpx;
}
.shortcut-item {
  border-radius: 24rpx;
  padding: 8rpx 4rpx 14rpx;
  text-align: center;
  background: transparent;
  border: none;
  box-shadow: none;
  transition: transform 0.15s;
}
.shortcut-item:active { transform: scale(0.94); }

.shortcut-img {
  width: 132rpx;
  height: 132rpx;
  display: block;
  margin: 0 auto 8rpx;
  border-radius: 22rpx;
  box-shadow: 0 6rpx 16rpx rgba(160, 100, 40, 0.13);
}
.shortcut-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
  font-family: var(--font-title);
}
.shortcut-method {
  display: block;
  font-size: 20rpx;
  color: var(--color-text-sub);
  margin-top: 4rpx;
  font-family: var(--font-title);
}

/* ---- 通用 section ---- */
.section {
  padding: 32rpx 24rpx 0;
  position: relative;
  z-index: 1;
}
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}
.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: var(--color-text);
}
.sign-more {
  font-size: 26rpx;
  color: var(--color-primary);
}

/* ---- 今日灵签卡 ---- */
.sign-card {
  border-radius: 28rpx;
  border: 2rpx solid var(--color-border-light);
  box-shadow: 0 4rpx 16rpx rgba(180, 120, 60, 0.09);
}

/* 未求签 */
.sign-card--unseen {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 28rpx 24rpx;
  background: linear-gradient(135deg, #FFFDF6, #FFF5E0);
  border-color: rgba(245, 166, 35, 0.25);
}
.sign-unseen-icon { font-size: 52rpx; flex-shrink: 0; opacity: 0.7; }
.sign-unseen-info { flex: 1; }
.sign-unseen-title {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
  margin-bottom: 6rpx;
}
.sign-unseen-hint {
  font-size: 22rpx;
  color: var(--color-text-sub);
  line-height: 1.6;
}
.sign-unseen-arrow {
  font-size: 36rpx;
  color: var(--color-primary);
  opacity: 0.6;
  flex-shrink: 0;
}

/* 已求签 */
.sign-card--drawn {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 28rpx 28rpx 24rpx;
  background: linear-gradient(135deg, #FFF9F0, #FFF0D6);
}
.sign-text {
  font-size: 27rpx;
  color: var(--color-text);
  line-height: 1.85;
}

/* 等级 badge（与灵签页一致） */
.sign-grade-badge {
  display: inline-flex;
  align-items: center;
  padding: 6rpx 28rpx;
  border-radius: 24rpx;
  align-self: flex-start;
}
.grade--daji  { background: linear-gradient(135deg, #FFD060, #F5A623, #FF8C69); box-shadow: 0 4rpx 12rpx rgba(245,166,35,0.45); }
.grade--ji    { background: linear-gradient(135deg, #FFBB55, #E8792A); box-shadow: 0 4rpx 12rpx rgba(232,121,42,0.35); }
.grade--xiaoji{ background: linear-gradient(135deg, #6ECFA8, #3EAF7C); box-shadow: 0 4rpx 12rpx rgba(62,175,124,0.30); }
.sign-grade-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 4rpx;
}

/* ---- 更多功能格 ---- */
.future-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}
.future-item {
  border-radius: 24rpx;
  padding: 26rpx 8rpx 22rpx;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 14rpx rgba(180, 120, 60, 0.08);
}
/* 三张卡片各自的渐变配色 */
.future-item--pink   { background: linear-gradient(150deg, #FFF0F5 0%, #FFE2ED 100%); }
.future-item--yellow { background: linear-gradient(150deg, #FFF8E7 0%, #FFF0C8 100%); }
.future-item--purple { background: linear-gradient(150deg, #F5F0FF 0%, #EBE0FF 100%); }

.future-emoji { display: block; font-size: 56rpx; margin-bottom: 10rpx; }

/* 主宠缘分：人 + 狗并排 */
.future-emoji-duo {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 4rpx;
  margin-bottom: 10rpx;
}
.duo-person { font-size: 52rpx; line-height: 1; }
.duo-pet    { font-size: 40rpx; line-height: 1; }
.future-name  { display: block; font-size: 26rpx; font-weight: 600; color: var(--color-text); }
.future-badge {
  display: inline-block;
  margin-top: 10rpx;
  padding: 4rpx 14rpx;
  background: rgba(180, 120, 60, 0.10);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: var(--color-text-sub);
}

/* ---- 动画 ---- */
@keyframes welcomeBounce {
  from { transform: scale(1) rotate(-6deg); }
  to   { transform: scale(1.08) rotate(6deg); }
}

/* 签左右轻摇，模拟悬挂感 */
@keyframes slipSway {
  from { transform: rotate(-5deg); }
  to   { transform: rotate(5deg);  }
}

@keyframes bdFloat {
  from { transform: translateY(0rpx) rotate(0deg); }
  to   { transform: translateY(-12rpx) rotate(15deg); }
}
