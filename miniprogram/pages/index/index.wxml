<view class="page-container">
  <!-- 欢迎遮罩 -->
  <view class="welcome-overlay {{showWelcome ? '' : 'welcome-overlay--hidden'}}">

    <!-- 背景爪印：大小不一散落全屏 -->
    <text class="paw pw-1">🐾</text>
    <text class="paw pw-2">🐾</text>
    <text class="paw pw-3">🐾</text>
    <text class="paw pw-4">🐾</text>
    <text class="paw pw-5">🐾</text>
    <text class="paw pw-6">🐾</text>
    <text class="paw pw-7">🐾</text>
    <text class="paw pw-8">🐾</text>
    <text class="paw pw-9">🐾</text>
    <text class="paw pw-10">🐾</text>
    <text class="paw pw-11">🐾</text>
    <text class="paw pw-12">🐾</text>

    <!-- 手绘签主体 -->
    <view class="slip-wrap">
      <!-- 签上方的细绳 -->
      <view class="slip-string"></view>
      <!-- 签正文 -->
      <view class="fortune-slip">
        <view class="slip-seal"></view>
        <text class="slip-top">大</text>
        <text class="slip-top">吉</text>
        <view class="slip-divider"></view>
        <text class="slip-main-char">签</text>
        <view class="slip-divider"></view>
        <text class="slip-brand">爪爪运</text>
      </view>
    </view>

    <text class="welcome-title">爪爪运</text>
    <text class="welcome-sub">✨ 毛孩子的命运小秘密 ✨</text>
  </view>

  <scroll-view scroll-y style="height:100vh;">

    <!-- 全局背景装饰：星星 & 月亮 -->
    <view class="bg-deco" aria-hidden="true">
      <text class="bd bd-star bd-1">✦</text>
      <text class="bd bd-moon bd-2">🌙</text>
      <text class="bd bd-star bd-3">✦</text>
      <text class="bd bd-star bd-4">✦</text>
      <text class="bd bd-moon bd-5">🌙</text>
      <text class="bd bd-star bd-6">✦</text>
      <text class="bd bd-star bd-7">✦</text>
      <text class="bd bd-moon bd-8">🌙</text>
      <text class="bd bd-star bd-9">✦</text>
      <text class="bd bd-star bd-10">✦</text>
    </view>

    <!-- Banner：插画铺满，标题叠加在上方 -->
    <view class="banner">
      <view class="banner-header">
        <text class="banner-app-name">宠物玄学小程序</text>
        <text class="banner-tagline">🐾 看看毛孩子的命运小秘密</text>
      </view>
      <image class="banner-img" src="/images/banner.jpg" mode="aspectFill"></image>
    </view>

    <!-- CTA 按钮 -->
    <view class="cta-wrap">
      <button class="btn-primary cta-btn" bindtap="onStartFortune">
        ✦ 开始为TA算一卦 ✦
      </button>
    </view>

    <!-- 宠物快捷入口：横排 4 列 -->
    <view class="shortcut-section">
      <view class="shortcut-grid">
        <view
          class="shortcut-item shortcut-item--{{item.id}}"
          wx:for="{{petShortcuts}}"
          wx:key="id"
          data-type="{{item.id}}"
          bindtap="onShortcutTap"
        >
          <image class="shortcut-img" src="/images/pet_{{item.id}}.png" mode="aspectFit"></image>
          <text class="shortcut-name">{{item.name}}</text>
          <text class="shortcut-method">{{item.method}}</text>
        </view>
      </view>
    </view>

    <!-- 今日灵签 -->
    <view class="section">
      <view class="section-header">
        <text class="section-title">🌿 今日灵签</text>
        <text class="sign-more" bindtap="onViewSign">{{signDrawn ? '查看详情' : '去求签'}} →</text>
      </view>

      <!-- 未求签 -->
      <view class="sign-card sign-card--unseen" bindtap="onViewSign" wx:if="{{!signDrawn}}">
        <text class="sign-unseen-icon">📜</text>
        <view class="sign-unseen-info">
          <text class="sign-unseen-title">今日还未求签</text>
          <text class="sign-unseen-hint">点击前往求签，看看今天运势如何</text>
        </view>
        <text class="sign-unseen-arrow">›</text>
      </view>

      <!-- 已求签 -->
      <view class="sign-card sign-card--drawn" wx:else>
        <view class="sign-grade-badge {{gradeClass}}">
          <text class="sign-grade-text">{{todaySignGrade}}</text>
        </view>
        <text class="sign-text">{{todaySign}}</text>
      </view>
    </view>

    <!-- 更多功能预留 -->
    <view class="section">
      <text class="section-title">✨ 更多功能</text>
      <view class="future-grid">
        <view class="future-item future-item--pink">
          <view class="future-emoji-duo">
            <text class="duo-person">🧑</text>
            <text class="duo-pet">🐕</text>
          </view>
          <text class="future-name">主宠缘分</text>
          <text class="future-badge">即将上线</text>
        </view>
        <view class="future-item future-item--yellow">
          <text class="future-emoji">🐾</text>
          <text class="future-name">宠物配对</text>
          <text class="future-badge">即将上线</text>
        </view>
        <view class="future-item future-item--purple">
          <text class="future-emoji">🌟</text>
          <text class="future-name">星座运势</text>
          <text class="future-badge">即将上线</text>
        </view>
      </view>
    </view>

    <view style="height:48rpx;"></view>
  </scroll-view>
</view>
