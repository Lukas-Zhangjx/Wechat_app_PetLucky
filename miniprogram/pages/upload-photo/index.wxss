/* ============================================
   上传照片页样式 — 对照演示图重制
   ============================================ */

/* ---- 标题区 ---- */
.upload-header {
  position: relative;
  padding: 40rpx 40rpx 28rpx;
  text-align: center;
  overflow: visible;
}

/* 散落装饰文字 */
.hd { position: absolute; pointer-events: none; user-select: none; opacity: 0.55; }
.hd-1 { font-size: 28rpx; top: 16rpx;  left: 24rpx;  color: var(--color-primary); transform: rotate(-20deg); }
.hd-2 { font-size: 32rpx; top: 24rpx;  right: 36rpx; color: var(--color-secondary); }
.hd-3 { font-size: 20rpx; top: 80rpx;  left: 52rpx;  color: var(--color-primary); transform: rotate(15deg); }
.hd-4 { font-size: 24rpx; top: 100rpx; right: 58rpx; color: var(--color-secondary); transform: rotate(-10deg); }
.hd-5 { font-size: 18rpx; top: 52rpx;  left: 50%;    color: var(--color-primary); }

/* 横幅主标题卡片 */
.header-banner {
  display: inline-block;
  background: linear-gradient(135deg, #FFECC0, #FFD98A);
  border: 2rpx solid #E8B84B;
  border-radius: 48rpx;
  padding: 16rpx 48rpx;
  box-shadow: 0 4rpx 16rpx rgba(245, 166, 35, 0.25);
  margin-bottom: 16rpx;
}
.banner-title {
  font-size: 34rpx;
  font-weight: bold;
  color: var(--color-text);
  letter-spacing: 2rpx;
  font-family: var(--font-title);
}

.header-sub {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-sub);
  margin-bottom: 16rpx;
}

.pet-summary {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: center;
  background: rgba(245,166,35,0.12);
  border-radius: 24rpx;
  padding: 10rpx 28rpx;
  margin-bottom: 16rpx;
}
.pet-summary-name {
  font-size: 28rpx;
  font-weight: bold;
  color: var(--color-text);
}
.pet-summary-detail {
  font-size: 24rpx;
  color: var(--color-text-sub);
}

.remaining-badge {
  display: inline-block;
  padding: 6rpx 20rpx;
  background: var(--color-secondary);
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #fff;
}

/* ---- section 间距 ---- */
.section { padding: 0 32rpx 32rpx; }

/* ---- 上传区（有预览） ---- */
.upload-preview-wrap {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  border: 3rpx solid var(--color-primary);
}
.preview-img { width: 100%; height: 400rpx; display: block; }
.remove-btn {
  position: absolute; top: 16rpx; right: 16rpx;
  width: 56rpx; height: 56rpx; border-radius: 50%;
  background: rgba(0,0,0,0.5); color: #fff;
  font-size: 28rpx; display: flex; align-items: center; justify-content: center;
}
.reselect-btn {
  position: absolute; bottom: 16rpx; right: 16rpx;
  padding: 8rpx 20rpx; background: rgba(0,0,0,0.5);
  border-radius: 20rpx; color: #fff; font-size: 24rpx;
}

/* ---- 上传区（示例图状态） ---- */
.upload-example-wrap {
  position: relative;
  width: 100%;
  height: 380rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: #F5ECD8;
  display: flex;
  align-items: center;
  justify-content: center;
  /* 虚线框在示例图上方叠加感 */
  box-shadow: inset 0 0 0 3rpx rgba(200, 150, 60, 0.35);
}
.example-bg-img {
  width: 100%;
  height: 100%;
  display: block;
  /* 稍微半透明，暗示这是"示例" */
  opacity: 0.88;
}
.example-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
}
.placeholder-emoji { font-size: 120rpx; }

/* 相机圆形按钮 — 叠在图片中下方 */
.camera-circle {
  position: absolute;
  bottom: 28rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFBE45, #F5A623);
  box-shadow: 0 6rpx 20rpx rgba(245, 166, 35, 0.50);
  font-size: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-hint-text {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text);
  font-weight: 500;
  margin-top: 20rpx;
}
.no-photo-btn {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #C8B8A0;
  margin-top: 24rpx;
  text-decoration: underline;
  line-height: 1.6;
}

.upload-sub-text {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: var(--color-text-sub);
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}


/* ---- 表单 ---- */
.form-card { padding: 0; overflow: hidden; }
.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
}
.form-label { font-size: 28rpx; color: var(--color-text); font-weight: 500; flex-shrink: 0; margin-right: 20rpx; }
.required  { color: var(--color-error); font-size: 28rpx; }
.recommend { font-size: 22rpx; color: var(--color-primary); }
.form-input { flex: 1; font-size: 26rpx; color: var(--color-text); text-align: right; }
.input-placeholder { font-size: 24rpx; color: #C8B8AA; }

.gender-btns { display: flex; gap: 16rpx; }
.gender-btn {
  padding: 10rpx 28rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: var(--color-text-sub);
  border: 2rpx solid var(--color-border);
  background: var(--color-bg);
}
.gender-btn--active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }

.picker-val { font-size: 26rpx; color: var(--color-text); display: flex; align-items: center; gap: 8rpx; }
.picker-arrow { color: var(--color-text-sub); font-size: 32rpx; }

/* ---- 提交按钮 ---- */
.submit-wrap { padding: 32rpx 40rpx; }
.submit-btn { width: 100%; font-size: 36rpx; }
.btn-disabled {
  background: var(--color-border);
  color: var(--color-text-sub);
  border-radius: 48rpx;
  padding: 28rpx 60rpx;
  font-size: 36rpx;
  text-align: center;
}
.btn-disabled::after { border: none; }
